{
  "hooks": {
    "PostToolUse": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$(git rev-parse --show-toplevel)/.claude/hooks/post-edit.sh\""
          }
        ],
        "matcher": "Edit"
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "/bin/bash \"$(git rev-parse --show-toplevel)/.claude/hooks/user-prompt-submit.sh\""
          }
        ],
        "matcher": "*"
      }
    ]
  }
}
